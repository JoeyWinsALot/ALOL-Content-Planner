<script>
const BRAND = {
  name: "A Lot Of Leads",
  url: "alotofleads.com",
  handle: "@alotofleads",
  tagline: "Smart CRM for growing businesses",
  cta: "Book a free demo at alotofleads.com",
  offer: "First month free, no contracts",
  product: "white-label GoHighLevel CRM with AI automation, lead nurture, landing pages, and SMS/email workflows"
};

const STEPS = {
  "1": { name: "Revenue Roadmap & KPIs", desc: "KPI back-engineering, income goals, reverse engineering how many leads and conversations you need per day to hit your revenue targets. The Lead to Close Formula." },
  "2": { name: "Client Clarity & Avatar", desc: "Identifying your ideal client avatar — high-paying, low-maintenance, long-retention. The Effort vs Value Matrix. Picking a niche that makes your life easier." },
  "3": { name: "Problem Discovery", desc: "Finding the 3 biggest pains your avatar has. Needs over wants. What keeps them up at night. Jobs-to-be-Done theory. Current State → Struggle → Desired State framework." },
  "4": { name: "Irresistible Offer Engine", desc: "Matching problems to solutions. Building your USP. Shiny object + real value formula. Brain dumping 50-100 ideas to craft a standout offer. Alex Hormozi $100M Offers principles." },
  "5": { name: "Backend Blueprint (CRM)", desc: "Setting up CRM, SMS, email automation, landing pages, social profiles, follow-up sequences. GoHighLevel/GoLevel setup. Converting interest into appointments automatically." },
  "6": { name: "Content Conversion System", desc: "Writing content using Problem-Agitate-Solve (PAS) and Hook-Story-Offer (HSO) frameworks. Creating reusable content templates. Brand voice that converts cold strangers into booked calls." },
  "7": { name: "Organic Growth & $1.80 Strategy", desc: "Gary Vee's $1.80 strategy — leaving 9 thoughtful comments on top posts in your niche daily. Post 3-5x weekly. Recycling top content every 30-45 days. Growing a warm audience for free." },
  "8": { name: "Dream 100 & Paid Ads", desc: "Building a Dream 100 list of influencers, pages, groups your ideal client follows. Running micro-retargeting ads ($5-10/day). Meta Advantage+ campaigns. Pouring gas on an already-working organic engine." },
  "9": { name: "Team Building & Outsourcing", desc: "Identifying time-consuming tasks to delegate. Hiring VAs from Upwork or OnlineJobs.ph. Creating SOPs. Delegating DMs, follow-ups, content — keeping only strategy, sales, and brand." },
  "10": { name: "Continuous Optimization", desc: "Weekly KPI reviews. Test → Learn → Apply growth loop. Split testing subject lines, landing pages, scripts, ads. Always improving, compounding growth month after month." },
  "any": { name: "LeadFlow Protocol (Mixed)", desc: "All 10 steps of the LeadFlow Protocol — KPI setting, avatar, problem discovery, offer building, CRM backend, content frameworks, organic growth, paid ads, outsourcing, and optimization." }
};

let selectedStep = "any";
let selectedTemplates = ["announce", "quote", "stats", "promo"];
let selectedQty = 5;

function selectStep(el) {
  document.querySelectorAll('.step-pill').forEach(p => p.classList.remove('active'));
  el.classList.add('active');
  selectedStep = el.dataset.step;
}

function toggleTemplate(el) {
  el.classList.toggle('selected');
  const tmpl = el.dataset.tmpl;
  if (el.classList.contains('selected')) {
    if (!selectedTemplates.includes(tmpl)) selectedTemplates.push(tmpl);
  } else {
    selectedTemplates = selectedTemplates.filter(t => t !== tmpl);
  }
}

function selectQty(el) {
  document.querySelectorAll('.qty-btn').forEach(b => b.classList.remove('selected'));
  el.classList.add('selected');
  selectedQty = parseInt(el.dataset.qty);
}

async function generateContent() {
  if (selectedTemplates.length === 0) {
    alert('Please select at least one template type.');
    return;
  }

  const btn = document.getElementById('genBtn');
  const main = document.getElementById('mainArea');
  const extraContext = document.getElementById('goalInput').value.trim();

  btn.disabled = true;
  btn.textContent = 'GENERATING...';

  main.innerHTML = `<div class="loading"><div class="spinner"></div><div class="loading-text">Writing your posts...</div></div>`;

  const stepInfo = STEPS[selectedStep];
  const templatesStr = selectedTemplates.join(', ');

  const prompt = `You are a social media content strategist for "${BRAND.name}" — ${BRAND.tagline}. Their product is: ${BRAND.product}. Website: ${BRAND.url}. Handle: ${BRAND.handle}. Their offer: ${BRAND.offer}.

They teach a 10-step framework called the LeadFlow Protocol for predictable client acquisition using Instagram & Facebook.

Generate exactly ${selectedQty} Instagram post ideas focused on: ${stepInfo.name}.
Step context: ${stepInfo.desc}

Template types to use (cycle through these): ${templatesStr}
${extraContext ? `Additional context from the user: ${extraContext}` : ''}

Return ONLY a JSON array (no markdown, no backticks, no preamble). Each item must have these exact keys:
- "postNumber": number
- "templateType": one of "announce", "quote", "stats", "promo" (cycle through the requested ones)
- "stepReference": which LeadFlow step this relates to (e.g. "Step 1: Revenue Roadmap")
- "hook": a punchy 1-line scroll-stopping hook (max 12 words, all caps optional, no emoji)
- "caption": a 3-5 sentence Instagram caption written in a direct, confident, no-fluff voice. Should educate, agitate a pain, or inspire action. Use line breaks. No hashtags here.
- "cta": a single call-to-action line (use "Book a free demo at alotofleads.com" or variation)
- "hashtags": 8-10 relevant hashtags as a single string separated by spaces

Keep the voice: direct, confident, results-focused. Like a business coach who has done it, not a motivational poster. Speak to coaches, consultants, service providers, and agency owners.`;

  try {
    const response = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        model: "claude-sonnet-4-20250514",
        max_tokens: 4000,
        messages: [{ role: "user", content: prompt }]
      })
    });

    const data = await response.json();
    const raw = data.content.map(i => i.text || "").join("");
    const clean = raw.replace(/```json|```/g, "").trim();
    const posts = JSON.parse(clean);

    renderPosts(posts, stepInfo.name, extraContext);
  } catch (err) {
    main.innerHTML = `<div class="error-box">Something went wrong generating posts. Please try again.<br><small style="opacity:0.6;margin-top:6px;display:block">${err.message}</small></div>`;
  }

  btn.disabled = false;
  btn.textContent = 'GENERATE POSTS →';
}

function renderPosts(posts, stepName, context) {
  const main = document.getElementById('mainArea');

  const badgeClass = { announce: 'badge-announce', quote: 'badge-quote', stats: 'badge-stats', promo: 'badge-promo' };
  const badgeLabel = { announce: 'Announcement', quote: 'Quote', stats: 'Stats', promo: 'Promo' };

  let html = `
    <div class="results-header">
      <div>
        <div class="results-title">${posts.length} posts generated</div>
        <div class="results-meta">${stepName}${context ? ' · ' + context : ''}</div>
      </div>
      <button class="copy-all-btn" onclick="copyAll()">Copy All</button>
    </div>
    <div class="posts-grid" id="postsGrid">
  `;

  posts.forEach((p, i) => {
    const bClass = badgeClass[p.templateType] || 'badge-general';
    const bLabel = badgeLabel[p.templateType] || p.templateType;
    const fullText = `HOOK: ${p.hook}\n\n${p.caption}\n\n${p.cta}\n\n${p.hashtags}`;

    html += `
      <div class="post-card" id="card-${i}">
        <div class="post-card-header">
          <div class="post-meta">
            <span class="post-num">Post ${p.postNumber}</span>
            <span class="post-type-badge ${bClass}">${bLabel}</span>
            <span class="step-badge">${p.stepReference}</span>
          </div>
          <button class="copy-btn" onclick="copyPost(${i}, this)" data-text="${encodeURIComponent(fullText)}">Copy</button>
        </div>
        <div class="post-card-body">
          <div class="post-section">
            <div class="post-section-label">Hook</div>
            <div class="hook-text">${p.hook}</div>
          </div>
          <div class="post-section">
            <div class="post-section-label">Caption</div>
            <div class="caption-text">${p.caption}</div>
          </div>
          <div class="post-section">
            <div class="post-section-label">CTA</div>
            <div class="cta-text">${p.cta}</div>
          </div>
          <div class="post-section">
            <div class="post-section-label">Hashtags</div>
            <div class="hashtags-text">${p.hashtags}</div>
          </div>
        </div>
      </div>
    `;
  });

  html += `</div>`;
  main.innerHTML = html;
  window._allPosts = posts;
}

function copyPost(i, btn) {
  const text = decodeURIComponent(btn.dataset.text);
  navigator.clipboard.writeText(text).then(() => {
    btn.textContent = 'Copied!';
    btn.classList.add('copied');
    setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 2000);
  });
}

function copyAll() {
  if (!window._allPosts) return;
  const text = window._allPosts.map(p =>
    `--- Post ${p.postNumber} (${p.templateType}) ---\nHOOK: ${p.hook}\n\n${p.caption}\n\n${p.cta}\n\n${p.hashtags}`
  ).join('\n\n\n');
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.querySelector('.copy-all-btn');
    btn.textContent = 'Copied all!';
    setTimeout(() => { btn.textContent = 'Copy All'; }, 2000);
  });
}
</script>
</body>
</html>
